{
  "name": "@kittyx/teto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Baguette-generated WebAssembly fork of the Thistle kernel.",
  "scripts": {
    "build": "npm run build:host && npm run teto:build",
    "build:host": "rm -rf build dist && tsc -p tsconfig.json",
    "teto:build": "bun baguette/src/compiler.ts",
    "teto:validate": "bun baguette/src/compiler.ts --validate-only",
    "teto:build:fast": "bun baguette/src/compiler.ts --skip-determinism-check",
    "test": "npm run build && npm run teto:validate",
    "check": "npm test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "assemblyscript": "0.28.19",
    "binaryen": "130.0.0-nightly.20260609",
    "bun": "1.3.14",
    "esbuild": "0.28.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "author": {
    "name": "Kitty Crow",
    "url": "https://kittycrow.dev"
  },
  "license": "MIT"
}
