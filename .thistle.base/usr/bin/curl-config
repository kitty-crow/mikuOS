# shellcheck disable=SC2006

prefix='/usr'
# Used in 'libdir'
# shellcheck disable=SC2034
exec_prefix="${prefix}"
# shellcheck disable=SC2034
includedir="${prefix}/include"

usage()
{
  cat <<EOF
Usage: curl-config [OPTION]

Available values for OPTION include:

  --built-shared        says 'yes' if libcurl was built shared
  --ca                  CA bundle install path
  --cc                  compiler
  --cflags              preprocessor and compiler flags
  --checkfor [version]  check for (lib)curl of the specified version
  --configure           the arguments given to configure when building curl
  --features            newline separated list of enabled features
  --help                display this help and exit
  --libs                library linking information
  --prefix              curl install prefix
  --protocols           newline separated list of enabled protocols
  --ssl-backends        output the SSL backends libcurl was built to support
  --static-libs         static libcurl library linking information
  --version             output version information
  --vernum              output version as a hexadecimal number
EOF

  exit "$1"
}

if test "$#" -eq 0; then
  usage 1
fi

while test "$#" -gt 0; do
  case "$1" in
  --built-shared)
    echo 'no'
    ;;

  --ca)
    echo '/etc/ssl/certs/ca-certificates.crt'
    ;;

  --cc)
    echo '/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/tools/bin/thistlecc'
    ;;

  --prefix)
    echo "$prefix"
    ;;

  --feature|--features)
    for feature in alt-svc AsynchDNS HSTS HTTPS-proxy IPv6 Largefile libz SSL threadsafe TLS-SRP UnixSockets ''; do
      test -n "$feature" && echo "$feature"
    done
    ;;

  --protocols)
    # shellcheck disable=SC2043
    for protocol in FILE FTP FTPS HTTP HTTPS WS WSS; do
      echo "$protocol"
    done
    ;;

  --version)
    echo 'libcurl 8.21.0'
    exit 0
    ;;

  --checkfor)
    checkfor="$2"
    cmajor=`echo "$checkfor" | cut -d. -f1`
    cminor=`echo "$checkfor" | cut -d. -f2`
    # when extracting the patch part we strip off everything after a
    # dash as that's used for things like version 1.2.3-pre1
    cpatch=`echo "$checkfor" | cut -d. -f3 | cut -d- -f1`

    vmajor=`echo '8.21.0' | cut -d. -f1`
    vminor=`echo '8.21.0' | cut -d. -f2`
    # when extracting the patch part we strip off everything after a
    # dash as that's used for things like version 1.2.3-pre1
    vpatch=`echo '8.21.0' | cut -d. -f3 | cut -d- -f1`

    if test "$vmajor" -gt "$cmajor"; then
      exit 0
    fi
    if test "$vmajor" -eq "$cmajor"; then
      if test "$vminor" -gt "$cminor"; then
        exit 0
      fi
      if test "$vminor" -eq "$cminor"; then
        if test "$cpatch" -le "$vpatch"; then
          exit 0
        fi
      fi
    fi

    echo "requested version $checkfor is newer than existing 8.21.0"
    exit 1
    ;;

  --vernum)
    echo '081500'
    exit 0
    ;;

  --help)
    usage 0
    ;;

  --cflags)
    if test "${prefix}/include" = '/usr/include'; then
      echo '-DCURL_STATICLIB'
    else
      echo "-DCURL_STATICLIB -I${prefix}/include"
    fi
    ;;

  --libs)
    if test "${exec_prefix}/lib" != '/usr/lib' && test "${exec_prefix}/lib" != '/usr/lib64'; then
      curllibdir="-L${exec_prefix}/lib "
    else
      curllibdir=''
    fi
    if test 'no' = 'no'; then
      echo "${curllibdir}-lcurl -lssl -lcrypto -lssl -lcrypto -lz -lssl -lcrypto -lz -lcrypt"
    else
      echo "${curllibdir}-lcurl"
    fi
    ;;

  --ssl-backends)
    echo 'OpenSSL'
    ;;

  --static-libs)
    if test 'yes' != 'no'; then
      echo "${exec_prefix}/lib/libcurl.a -L/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr/lib -L/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/lib -L/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr/lib -lssl -lcrypto -lssl -lcrypto -lz -lssl -lcrypto -lz -lcrypt"
    else
      echo 'curl was built with static libraries disabled' >&2
      exit 1
    fi
    ;;

  --configure)
    echo " '--build=x86_64-linux-gnu' '--host=riscv64-unknown-linux-musl' '--prefix=/usr' '--bindir=/usr/bin' '--disable-shared' '--enable-static' '--disable-docs' '--disable-manual' '--disable-debug' '--disable-ldap' '--disable-ldaps' '--disable-rtsp' '--disable-dict' '--disable-telnet' '--disable-tftp' '--disable-pop3' '--disable-imap' '--disable-smtp' '--disable-gopher' '--disable-mqtt' '--disable-smb' '--disable-ipfs' '--without-libpsl' '--without-libidn2' '--without-brotli' '--without-zstd' '--without-nghttp2' '--without-nghttp3' '--without-libssh2' '--with-openssl=/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr' '--with-zlib=/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr' '--with-ca-bundle=/etc/ssl/certs/ca-certificates.crt' 'build_alias=x86_64-linux-gnu' 'host_alias=riscv64-unknown-linux-musl' 'CC=/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/tools/bin/thistlecc' 'CFLAGS=-O2 -pipe -march=rv64gc -mabi=lp64d -mno-relax -D_GNU_SOURCE' 'LDFLAGS=-static -no-pie -L/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr/lib -L/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/lib -Wl,--no-relax -Wl,--build-id=none' 'LIBS=-lssl -lcrypto -lz -lcrypt' 'CPPFLAGS=-I/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/sysroot/usr/include' 'CPP=/mikuos/build/_______KITTYX/mikuOS/.rebuild-userland/tools/bin/thistlecc -E'"
    ;;

  *)
    echo "unknown option: $1"
    usage 1
    ;;
  esac
  shift
done

exit 0
